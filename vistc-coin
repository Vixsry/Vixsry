#include <ESP8266WiFi.h>
#include <BlynkSimpleEsp8266.h>

#define BLYNK_PRINT Serial
#define BLYNK_TEMPLATE_ID "ID"
#define BLYNK_TEMPLATE_NAME "Smart Light"
#define BLYNK_AUTH_TOKEN "AUTH TOKEN"

char ssid[] = "SSID";
char pass[] = "PASS";

int relayPins[] = {D1, D2, D3, D4, D5, D6, D7, D8};

void setup() {
  Serial.begin(115200);
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);
  for (int i = 0; i < 8; i++) {
    pinMode(relayPins[i], OUTPUT);
    digitalWrite(relayPins[i], HIGH);
  }
}

BLYNK_WRITE(V0) { 
  digitalWrite(relayPins[0], param.asInt()); 
}

BLYNK_WRITE(V1) { 
  digitalWrite(relayPins[1], param.asInt()); 
}

BLYNK_WRITE(V2) { 
  digitalWrite(relayPins[2], param.asInt()); 
}

BLYNK_WRITE(V3) { 
  digitalWrite(relayPins[3], param.asInt()); 
}

BLYNK_WRITE(V4) { 
  digitalWrite(relayPins[4], param.asInt()); 
}

BLYNK_WRITE(V5) { 
  digitalWrite(relayPins[5], param.asInt()); 
}

BLYNK_WRITE(V6) { 
  digitalWrite(relayPins[6], param.asInt()); 
}

BLYNK_WRITE(V7) { 
  digitalWrite(relayPins[7], param.asInt()); 
}

void loop() {
  Blynk.run();
}